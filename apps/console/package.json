{
  "name": "@3amoncall/console",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "typecheck:e2e": "tsc --project tsconfig.e2e.json",
    "lint": "eslint src --max-warnings 0",
    "lint:css": "stylelint 'src/**/*.css'",
    "e2e": "playwright test",
    "e2e:receiver-served": "playwright test --config playwright.receiver-served.config.ts",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@3amoncall/core": "workspace:*",
    "@tanstack/react-query": "^5.74.4",
    "@tanstack/react-router": "^1.114.22",
    "clsx": "^2.1.1",
    "i18next": "^25.10.10",
    "lucide-react": "^0.577.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^16.6.6"
  },
  "devDependencies": {
    "@3amoncall/config-eslint": "workspace:*",
    "@3amoncall/config-typescript": "workspace:*",
    "@eslint/js": "^9.23.0",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.1",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.23.0",
    "jsdom": "^26.1.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.29.0",
    "vite": "^6.3.1",
    "vitest": "^3.1.1"
  }
}
