{
  "name": "@3am/cli",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "3am": "./dist/cli.js",
    "3am-cli": "./dist/index.js"
  },
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "lint": "eslint src --max-warnings 0"
  },
  "dependencies": {
    "@3am/core": "workspace:*",
    "@3am/diagnosis": "workspace:*",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@3am/config-eslint": "workspace:*",
    "@3am/config-typescript": "workspace:*",
    "@eslint/js": "^9.0.0",
    "@types/node": "^24.12.2",
    "eslint": "^9.0.0",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.2"
  }
}
