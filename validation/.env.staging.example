# Copy this file to validation/.env.staging and fill in real values.
# NEVER commit validation/.env.staging — it contains a real staging token.
#
# Usage:
#   docker compose -f docker-compose.yml -f docker-compose.staging.yml \
#     --env-file .env.staging up -d

# The HTTPS URL of the staging Receiver on Cloudflare Workers (no trailing slash).
# Find this in Cloudflare dashboard → Workers & Pages → 3am-receiver.
RECEIVER_ENDPOINT=https://3am-receiver.your-subdomain.workers.dev

# The Bearer token for staging Receiver auth.
# Must match the RECEIVER_AUTH_TOKEN secret set in CF Workers.
# Generate with: openssl rand -hex 32
RECEIVER_AUTH_TOKEN=replace-me
